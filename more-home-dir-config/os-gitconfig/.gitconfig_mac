# OS-specific git configuration for Mac

[credential]
	helper = osxkeychain
[diff]
	tool = bcomp
[difftool "bcomp"]
	trustExitCode = true
	cmd = `/usr/local/bin/bcomp $LOCAL $REMOTE`
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[pager]
  diff = `brew --prefix git`/share/git-core/contrib/diff-highlight/diff-highlight | less

# Sign commits on my work computer, but not on my personal one.
[user]
	signingkey = /Users/sam/.ssh/id_ed25519.pub
[tag]
  gpgsign = true
[gpg]
  format = ssh
[commit]
  gpgsign = true
